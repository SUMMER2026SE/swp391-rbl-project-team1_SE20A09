# ══════════════════════════════════════════════
#  Sport Venue Management — Environment Template
#  Copy file này thành .env và điền các giá trị
#  KHÔNG COMMIT file .env lên Git!
# ══════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────
POSTGRES_DB=sportvenue
POSTGRES_USER=sportvenue_user
# Phải khớp SPRING_DATASOURCE_PASSWORD khi chạy backend (mặc định dev: changeme)
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────
REDIS_PORT=6379
# Phải khớp SPRING_DATA_REDIS_PASSWORD của backend (docker-compose dùng changeme nếu không set)
REDIS_PASSWORD=changeme

# ── MinIO ──────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password_here
MINIO_PORT_API=9000
MINIO_PORT_CONSOLE=9001

# ── Backend (Spring Boot) ──────────────────────
SPRING_PROFILES_ACTIVE=dev
JWT_SECRET=your_jwt_secret_key_min_256_bits_change_this_in_production
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=604800

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email SMTP — đặt trong backend/.env (không đặt ở file .env gốc để tránh ghi đè cấu hình)
# Resend: MAIL_HOST=smtp.resend.com, MAIL_USERNAME=resend, MAIL_PASSWORD=<api_key>, MAIL_FROM=onboarding@resend.dev
# Gmail: MAIL_HOST=smtp.gmail.com, MAIL_USERNAME=<email>, MAIL_PASSWORD=<app_password_16_chars>

# ── Frontend (Next.js) ─────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000
