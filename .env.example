# ── Goong Map ───────────────────────────────────────────────────────
# Lấy tại: https://account.goong.io/
GOONG_API_KEY=your_goong_api_key_here

# ── VNPay sandbox (UC-CUS-02) ──────────────────
# Lấy tại: https://sandbox.vnpayment.vn/
VNPAY_TMN_CODE=your_vnpay_tmn_code_here
VNPAY_HASH_SECRET=your_vnpay_hash_secret_here
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Return URL: VNPay redirect browser về BE endpoint trước, BE xác thực checksum + cập nhật DB,
# rồi mới redirect browser sang FRONTEND_RETURN_URL bên dưới.
VNPAY_RETURN_URL=http://localhost:8080/api/v1/payments/vnpay-return
# IPN: dùng ngrok tunnel khi test local - https://<id>.ngrok.io/api/v1/payments/vnpay-ipn
VNPAY_IPN_URL=http://localhost:8080/api/v1/payments/vnpay-ipn
VNPAY_FRONTEND_RETURN_URL=http://localhost:3000/payments/result

# ── Frontend (Next.js) ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXTAUTH_SECRET=1cc0d08028d28783e79d590493ee22ea
