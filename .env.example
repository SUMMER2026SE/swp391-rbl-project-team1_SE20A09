# ══════════════════════════════════════════════════════════════════
#  Sport Venue Management — Environment Template
#  Hướng dẫn:
#    1. Copy file này: cp .env.example .env
#    2. Điền các giá trị thực của bạn vào .env
#    3. TUYỆT ĐỐI KHÔNG commit file .env lên Git
# ══════════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_DB=sportvenue
POSTGRES_USER=sportvenue_user
# Đặt mật khẩu riêng cho máy bạn, không dùng "changeme" ở production
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_PORT=5433

# ── Redis ───────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ── MinIO (Object Storage) ──────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password_here
MINIO_PORT_API=9000
MINIO_PORT_CONSOLE=9001

# ── File Upload ─────────────────────────────────────────────────────
FILE_UPLOAD_DIR=/app/uploads
FILE_BASE_URL=http://localhost:8080
FILE_MAX_SIZE_BYTES=5242880

# ── Backend (Spring Boot) ───────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# Tạo JWT secret ngẫu nhiên (min 32 ký tự):
#   Linux/macOS: openssl rand -hex 32
#   Windows:     [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
JWT_SECRET=your_jwt_secret_min_256_bits_replace_this

JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=604800

# ── Google OAuth2 ───────────────────────────────────────────────────
# Lấy tại: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Email SMTP ──────────────────────────────────────────────────────
# Chọn 1 trong 2 cấu hình bên dưới:
#
# Option A — Gmail App Password:
#   1. Vào Google Account → Security → 2-Step Verification → App Passwords
#   2. Tạo App Password (16 ký tự không dấu cách)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_FROM=your_gmail@gmail.com
#
# Option B — Resend (khuyên dùng cho dev):
#   1. Đăng ký tại https://resend.com → lấy API key
# MAIL_HOST=smtp.resend.com
# MAIL_USERNAME=resend
# MAIL_PASSWORD=re_your_api_key_here
# MAIL_FROM=onboarding@resend.dev
#
# Đặt MAIL_MOCK=true để bỏ qua gửi email thật khi dev local
MAIL_MOCK=true

# ── Goong Map ───────────────────────────────────────────────────────
# Lấy tại: https://account.goong.io/
GOONG_API_KEY=your_goong_api_key_here

# ── Frontend (Next.js) ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Tạo NEXTAUTH_SECRET ngẫu nhiên:
#   Linux/macOS: openssl rand -hex 32
#   Windows:     [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000
