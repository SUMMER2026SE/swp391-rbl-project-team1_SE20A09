# ── Environment Template for Frontend ──────────
# Copy this file to '.env' and adjust the variables as needed

# NextAuth configuration
NEXTAUTH_SECRET=1cc0d08028d28783e79d590493ee22ea
# Phải khớp cổng bạn mở trên trình duyệt (3000 hoặc 3001)
